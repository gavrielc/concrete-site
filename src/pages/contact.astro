---
import PageLayout from "../layouts/PageLayout.astro";
import bullet from '../assets/icons/bullet.svg';
---

<PageLayout pageTitle="Contact | Public Relations for serious tech companies | Concrete Media">
    <section class='contact-hero'>
        <h3>Let's connect to discuss your PR needs</h3>
        <a class="email-button" href="mailto:zack@concrete.media">zack@concrete.media</a>
    </section>
    <section class="offices">
        <div class="office-location">
            <iframe src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d54282.40533331481!2d35.18313544691752!3d31.752743999999993!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x1502d7e1c8c8b099%3A0xfd0c5f7c7184d7be!2sGeneral%20Pierre%20Koenig%20St%2028%2C%20Jerusalem!5e0!3m2!1sen!2sil!4v1694523121272!5m2!1sen!2sil" width="100%" height="380" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            <div class="location-desc">
                <img src={bullet.src} alt="" />
                <p class="name">Jerusalem office</p>
                <p class="address">General Pierre Koenig St 28, Jerusalem</p>
            </div>
        </div>
    </section>
</PageLayout>

<style lang="scss">
    @mixin normal-text {
        font-family: 'Inter';
        font-size: 16px;
        color: rgba(0, 0, 0, 0.6);
    }

    .contact-hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding-top: 110px;
        padding-bottom: 40px;

        h3 {
            margin: 0 0 32px;
        }

        .email-button {
            display: inline-block;
            padding: 16px 40px;
            background-color: #7022FB;
            color: #fff;
            font-family: 'Outfit';
            font-weight: 600;
            font-size: 18px;
            text-decoration: none;
            border-radius: 8px;
            transition: background-color 0.2s;

            &:hover {
                background-color: #5a1ad4;
            }
        }
    }

    .offices {
        gap: 32px;
        flex-wrap: wrap;
    }

    .office-location {
        flex: 1 0 385px;

        .map {
            border-radius: 16px;
        }

        .location-desc {
            position: relative;
            margin-top: 16px;
        }

        .address {
            @include normal-text;
        }

        .name, .address {
            margin: 0 0 8px 20px;
        }

        img {
            position: absolute;
            top: 10px;
        }
    }

    .name {
        font-family: 'Outfit';
        font-weight: 600;
        font-size: 24px;
        color: #7022FB;
        margin: 0;
    }

    @media screen and (max-width: 827px) {
        .contact-hero {
            padding-top: 40px;
        }
    }

    @media screen and (max-width: 367px) {
        .office-location {
            flex: 1 0 200px;
        }
    }
</style>
